# AI support chat (/api/chat) — free key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Supabase — stores every bot's config (table: bots). Free tier is fine.
#   SUPABASE_URL:  Project Settings -> API -> Project URL
#   SERVICE ROLE:  Project Settings -> API -> service_role secret
#   SERVER-ONLY — never expose the service role key to the browser / widget.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here

# Optional: override the model (default: llama-3.3-70b-versatile)
# CHAT_MODEL=llama-3.3-70b-versatile

# Cross-origin embedding is now controlled PER BOT via the bots.allowed_origins
# column (empty = allow any site). No global ALLOWED_ORIGINS env var needed.
