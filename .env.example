# AI support chat (/api/chat) — free key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the model (default: llama-3.3-70b-versatile)
# CHAT_MODEL=llama-3.3-70b-versatile

# Optional: restrict which sites may embed the widget cross-origin.
# Default is * (any site). Comma-separated list of origins.
# ALLOWED_ORIGINS=https://your-portfolio.com,https://your-blog.com
